{
  "name": "@phobos-shell/shell",
  "version": "2.1.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/phobos/*",
    "libs/lsx/*"
  ],
  "scripts": {
    "lerna": "lerna",
    "build": "lerna run build",
    "k8s:restart": "kubectl rollout restart deployment/phobos-shell-deployment",
    "mirrord:backend": "mirrord exec --target deployment/phobos-shell-deployment -- npm run start:backend:dev",
    "start:frontend": "npm run start -w apps/frontend",
    "start:frontend:dev": "npm run start:dev -w apps/frontend",
    "start:backend": "npm run start -w apps/backend",
    "start:backend:dev": "npm run start:dev -w apps/backend",
    "release": "release-it --workspaces",
    "release:pre": "npm run release -- --preRelease=alpha --no-git --no-github",
    "test:frontend": "npm run test -w apps/frontend"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.1.5",
    "@angular/cli": "21.1.5",
    "@angular/compiler-cli": "21.1.5",
    "@nestjs/cli": "^11.0.16",
    "@release-it/bumper": "^7.0.5",
    "lerna": "^9.0.4",
    "release-it": "^19.2.4"
  },
  "overrides": {
    "ajv": "^8.17.1",
    "glob": "^11.1.0",
    "tar": "^7.5.8"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "github": {
      "release": true
    },
    "git": {
      "requireCleanWorkingDir": false
    },
    "npm": {
      "publish": false,
      "bump": false
    },
    "plugins": {
      "@release-it/bumper": {
        "out": [
          "apps/*/package.json"
        ]
      }
    },
    "hooks": {
      "after:release": [
        "docker build -t prim/phobos-shell:${version} -t prim/phobos-shell:latest ."
      ]
    }
  }
}
